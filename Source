# 2. Interactive table: summary by state
# Convert 'family_member_count' to numeric type
# Assuming format 'XpYc' means X parents and Y children, total X+Y members
def parse_family_member_count(s):
    if isinstance(s, str):
        parts = s.split('p')
        if len(parts) == 2:
            try:
                parents = int(parts[0])
                children_str = parts[1].replace('c', '')
                children = int(children_str)
                return parents + children
            except ValueError:
                return None # Handle cases where conversion to int fails
    return None # For non-string or unparseable formats

# Apply the conversion if the column is still of object type
